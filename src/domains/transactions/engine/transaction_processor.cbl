000001 IDENTIFICATION DIVISION.
000002 PROGRAM-ID. TRANSACTION-PROCESSOR.
000003 AUTHOR. Gemini.
000004
000005 ENVIRONMENT DIVISION.
000006 INPUT-OUTPUT SECTION.
000007 FILE-CONTROL.
000008     SELECT TRANSACTION-IN ASSIGN TO KEYBOARD
000009         ORGANIZATION IS SEQUENTIAL
000010         ACCESS MODE IS SEQUENTIAL
000011         FILE STATUS IS FS-TRANSACTION-IN.
000012     SELECT REPORT-OUT ASSIGN TO DISPLAY
000013         ORGANIZATION IS LINE SEQUENTIAL
000014         ACCESS MODE IS SEQUENTIAL
000015         FILE STATUS IS FS-REPORT-OUT.
000016
000017 DATA DIVISION.
000018 FILE SECTION.
000019 FD  TRANSACTION-IN
000020     RECORD CONTAINS 59 CHARACTERS.
000021 01  TRANSACTION-RECORD.
000022     COPY "transaction_record.cpy".
000023
000024 FD  REPORT-OUT.
000025 01  REPORT-RECORD.
000026     05 RP-TOTAL-TRANSACTIONS   PIC 9(08).
000027     05 FILLER                  PIC X(01) VALUE SPACE.
000028     05 RP-TOTAL-AMOUNT         PIC S9(13)V99.
000029
000030 WORKING-STORAGE SECTION.
000031 01  WS-WORK-AREAS.
000032     05 WS-EOF                  PIC X(1) VALUE 'N'.
000033     05 WS-COUNTER              PIC 9(8) VALUE 0.
000034     05 WS-TOTAL-AMOUNT         PIC S9(13)V99 VALUE 0.
000035     05 WS-EXIT-CODE            PIC 9(1) VALUE 0.
000036
000037 01  FILE-STATUS-CODES.
000038     05 FS-TRANSACTION-IN       PIC X(2).
000039     05 FS-REPORT-OUT           PIC X(2).
000040
000041 PROCEDURE DIVISION.
000042 MAIN-PROCEDURE.
000043*
000044     OPEN INPUT TRANSACTION-IN.
000045     IF FS-TRANSACTION-IN NOT = "00"
000046        DISPLAY "Fatal: Error opening input file. Status: "
000047                FS-TRANSACTION-IN UPON SYSERR
000048        MOVE 1 TO WS-EXIT-CODE
000049        GO TO CLEANUP-AND-EXIT
000050     END-IF.
000051*
000052     OPEN OUTPUT REPORT-OUT.
000053     IF FS-REPORT-OUT NOT = "00"
000054        DISPLAY "Fatal: Error opening output file. Status: "
000055                FS-REPORT-OUT UPON SYSERR
000056        MOVE 1 TO WS-EXIT-CODE
000057        GO TO CLEANUP-AND-EXIT
000058     END-IF.
000059*
000060     PERFORM UNTIL WS-EOF = 'Y'
000061         READ TRANSACTION-IN
000062             AT END
000063                 MOVE 'Y' TO WS-EOF
000064             NOT AT END
000065                 IF FS-TRANSACTION-IN = "00"
000066                     ADD 1 TO WS-COUNTER
000067                     ADD TR-AMOUNT TO WS-TOTAL-AMOUNT
000068                 ELSE
000069                     DISPLAY "Warning: Error reading input "
000070                     DISPLAY "record. Status: "
000071                             FS-TRANSACTION-IN UPON SYSERR
000072                     MOVE 'Y' TO WS-EOF
000073                     MOVE 1 TO WS-EXIT-CODE
000074                 END-IF
000075         END-READ
000076     END-PERFORM.
000077*
000078     MOVE WS-COUNTER TO RP-TOTAL-TRANSACTIONS.
000079     MOVE WS-TOTAL-AMOUNT TO RP-TOTAL-AMOUNT.
000080     WRITE REPORT-RECORD.
000081     IF FS-REPORT-OUT NOT = "00"
000082         DISPLAY "Fatal: Error writing to output file. "
000083         DISPLAY "Status: " FS-REPORT-OUT UPON SYSERR
000084         MOVE 1 TO WS-EXIT-CODE
000085     END-IF.
000086*
000087 CLEANUP-AND-EXIT.
000088     CLOSE TRANSACTION-IN.
000089     CLOSE REPORT-OUT.
000090     STOP RUN WS-EXIT-CODE.
000091*
000092 END PROGRAM TRANSACTION-PROCESSOR.